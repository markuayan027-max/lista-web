{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --filter @workspace/api-server...",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/api-server run typecheck",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
