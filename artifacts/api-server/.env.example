# LISTA API server — local Node (`pnpm run start`) or Cloudflare Worker (`lista-web`).
# Copy to repo root `.env` for local dev. On Workers, set the same names in Dashboard → Variables / Secrets
# (secrets are never committed; see `wrangler.toml` [vars] for safe defaults pushed with deploy).

# --- Required (production) ---
# DATABASE_URL=postgresql://...        # Worker: use Hyperdrive URL as this secret.
# GROQ_API_KEY=                        # Homepage AI chat (server-only).

# --- Optional (Groq) ---
# GROQ_MODEL=llama-3.3-70b-versatile   # Also in wrangler.toml [vars] for Workers.
# GROQ_KEY=                            # Alias for GROQ_API_KEY
# VITE_GROQ_API_KEY=                   # Alias for GROQ_API_KEY (not used by Vite in this package)

# --- InsForge (must match project that issues login tokens) ---
# INSFORGE_URL=https://....insforge.app
# VITE_INSFORGE_URL=                   # Same as INSFORGE_URL if your tooling expects VITE_

# --- App URLs (staff activation emails, etc.) ---
# LISTA_APP_URL=https://lista.dpdns.org
# VITE_APP_URL=

# --- Local Node only (not used by src/worker.ts) ---
# PORT=8787
# REDIS_URL=                           # Socket.io scale-out; optional

# LOG_LEVEL=info
