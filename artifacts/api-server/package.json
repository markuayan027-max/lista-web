{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && cross-env NODE_ENV=development pnpm run start",
    "dev:watch": "cross-env NODE_ENV=development node --watch ./build.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --env-file=../../.env ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:typegen": "wrangler types"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/express-rate-limit": "^6.0.2",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.10.1",
    "pino": "^9",
    "pino-http": "^10",
    "socket.io": "^4.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "wrangler": "^4"
  }
}
