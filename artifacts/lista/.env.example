# InsForge backend (Dashboard → Project → API keys)
# Copy to artifacts/lista/.env — use real keys (not placeholders).
# Pilot: from repo root run `pnpm run pilot-smoke` (Playwright + InsForge HTTP probes).
# Docs: artifacts/lista/docs/PRE-PRODUCTION-CHECKLIST.md · FINAL-PILOT-READINESS.md
VITE_INSFORGE_URL=https://2r6c3q25.ap-southeast.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_api_key_here

# Optional — only if the app is not served from domain root (see vite.config.ts)
# BASE_PATH=/

# Optional — set only when LISTA uses a dedicated API host (separate from shared projects)
# Example: VITE_LISTA_API_BASE_URL=https://api-lista.dpdns.org
# When unset, frontend uses same-origin /api (Vercel rewrite path).
# VITE_LISTA_API_BASE_URL=

# Homepage chat (Groq) — set on API server / repo root .env, NOT in Vite (server-side only)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# Full API + Worker env reference: artifacts/api-server/.env.example
