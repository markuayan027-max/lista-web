# LISTA — Vercel lista-frontend (Production + Preview)
# 1. Replace every REPLACE_ME value below (from InsForge + Postgres dashboards).
# 2. Vercel → lista-frontend → Settings → Environment Variables → Add → Import .env
# 3. Paste this whole file (or use Import .env). Turn Sensitive ON. Scope: Production and Preview.
# 4. Delete NODE_ENV from Vercel if you added it — it breaks the build (see bottom).
# 5. Save, then redeploy Production.

DATABASE_URL=REPLACE_ME_postgresql_connection_string

INSFORGE_URL=https://2r6c3q25.ap-southeast.insforge.app
VITE_INSFORGE_URL=https://2r6c3q25.ap-southeast.insforge.app
VITE_INSFORGE_ANON_KEY=REPLACE_ME_insforge_anon_api_key

LISTA_APP_URL=https://lista.dpdns.org
VITE_APP_URL=https://lista.dpdns.org

GROQ_API_KEY=REPLACE_ME_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

LOG_LEVEL=info

# Do NOT add NODE_ENV — Vercel sets it at runtime. NODE_ENV=production here makes
# pnpm skip devDependencies → build error: Cannot find package 'esbuild'.
