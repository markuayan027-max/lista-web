{
  "name": "lista-frontend",
  "installCommand": "pnpm install --frozen-lockfile --prod=false",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/lista run build",
  "outputDirectory": "artifacts/lista/dist/public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api(?:/|$)).*)", "destination": "/index.html" }
  ]
}
